# NapCat配置
# 获取方式：NapCat设置中的WebSocket Token
NAPCAT_TOKEN=your_napcat_token_here

# QQ邮箱配置（用于心跳检测邮件提醒）
# 发送者QQ邮箱（必须与授权码对应的邮箱一致）
QQ_EMAIL_SENDER=your_qq_email@qq.com

# 接收者邮箱（可以是你自己的其他邮箱）
QQ_EMAIL_RECEIVER=recipient_email@qq.com

# QQ邮箱授权码（非密码）
# 获取方式：登录QQ邮箱 → 设置 → 账户 → POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务
# 开启POP3/SMTP服务，获取授权码
QQ_EMAIL_AUTH_CODE=your_qq_email_auth_code_here

# 注意：
# 1. 复制本文件为 environment.env（git会忽略此文件）
# 2. 填写真实的配置信息
# 3. QQ邮箱授权码需要确保开启SMTP服务才能发送邮件
# 4. 建议定期更新授权码以确保安全性